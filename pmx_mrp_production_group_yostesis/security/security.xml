<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <record id="mrp_production_group_rule_company" model="ir.rule">
      <field name="name">Agrupación OF - multiempresa</field>
      <field name="model_id" ref="model_mrp_production_group"/>
      <field name="domain_force">[('company_id', 'in', company_ids)]</field>
      <field name="groups" eval="[(4, ref('mrp.group_mrp_user'))]"/>
    </record>

    <record id="mrp_production_group_component_detail_rule_company" model="ir.rule">
      <field name="name">Agrupación OF Components Detail - multiempresa</field>
      <field name="model_id" ref="model_mrp_production_group_component_detail"/>
      <field name="domain_force">[('company_id', 'in', company_ids)]</field>
      <field name="groups" eval="[(4, ref('mrp.group_mrp_user'))]"/>
    </record>

    <record id="mrp_production_group_component_rule_company" model="ir.rule">
      <field name="name">Agrupación OF Components - multiempresa</field>
      <field name="model_id" ref="model_mrp_production_group_component"/>
      <field name="domain_force">[('company_id', 'in', company_ids)]</field>
      <field name="groups" eval="[(4, ref('mrp.group_mrp_user'))]"/>
    </record>

  </data>
</odoo>
