<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="report_picking_patch" inherit_id="indaws_custom_reports.report_packing_list_document">
      <xpath expr="//th[@name='th_boxes']" position="replace">
        <th name="th_boxes" class="text-left" style="width:5.0cm;border-bottom:1px solid black;">CAJAS</th>
      </xpath>
      <xpath expr="//th[@name='th_quantity']" position="replace">
        <th name="th_quantity" class="text-center" style="width:4.0cm;border-bottom:1px solid black;">CANTIDAD</th>
      </xpath>
      <xpath expr="//th[@name='th_lb_total']" position="replace">
        <th name="th_lb_total" class="text-center" style="width:4.0cm;border-bottom:1px solid black;">PESO&#160;(Kg)</th>
      </xpath>
      <xpath expr="//th[@name='th_wide']" position="replace">
        <th name="th_wide" class="text-center" style="width:4.0cm;border-bottom:1px solid black;">ANCHO</th>
      </xpath>
      <xpath expr="//th[@name='th_height']" position="replace">
        <th name="th_height" class="text-center" style="width:4.0cm;border-bottom:1px solid black;">ALTO</th>
      </xpath>
      <xpath expr="//th[@name='th_depth']" position="replace">
        <th name="th_depth" class="text-center" style="width:4.0cm;border-bottom:1px solid black;">FONDO</th>
      </xpath>
      <xpath expr="//th[@name='th_depth']" position="after">
        <th name="th_cbm" class="text-center" style="width:4.0cm;border-bottom:1px solid black;">VOL&#160;(m³)</th>
      </xpath>

      <xpath expr="//td[@name='td_lb_total']" position="replace">
        <td name="td_lb_total" class="text-center" style="font-weight:bold;">
          <span t-field="move.kg_line_total" t-options="{'widget':'float','precision_digits': 2}"/>
        </td>
      </xpath>
      <xpath expr="//td[@name='td_depth']" position="after">
        <td name="td_cbm" class="text-center">
          <span t-field="move.cbm_line" t-options="{'widget':'float','precision_digits': 4}"/>
        </td>
      </xpath>
    </template>

    <!---PARCHE FOOTER -->
    <template id="report_picking_footer_patch" inherit_id="indaws_custom_reports.report_footer">
      <xpath expr="//th[@name='th_boxes']" position="replace">
        <th name="th_boxes" class="text-left" style="width:5.0cm;font-weight:bold;">TOTAL POR FACTURA</th>
      </xpath>
      <xpath expr="//th[@name='th_quantity']" position="replace">
        <th name="th_quantity" class="text-center" style="width:4.0cm;border-bottom:1px solid black;">CANTIDAD TOTAL</th>
      </xpath>
      <xpath expr="//th[@name='th_lb_total']" position="replace">
        <th name="th_lb_total" class="text-center" style="width:4.0cm;border-bottom:1px solid black;">PESO TOTAL&#160;(Kg)</th>
      </xpath>
      <xpath expr="//th[@name='th_lb_total']" position="after">
        <th name="th_cbm_total" class="text-center" style="width:4.0cm;border-bottom:1px solid black;">VOL TOTAL&#160;(m³)</th>
      </xpath>

      <xpath expr="//td[@name='td_lb_total']/span" position="attributes">
        <attribute name="t-field">o.kg_paq_total_pr</attribute>
        <attribute name="t-options">{'widget':'float','precision_digits':2}</attribute>
      </xpath>
      <xpath expr="//td[@name='td_lb_total']" position="after">
        <td name="td_cbm_total" class="text-center">
          <span t-field="o.cbm_total" t-options="{'widget':'float','precision_digits':4}"/>
        </td>
      </xpath>
    </template>
  </data>
</odoo>
