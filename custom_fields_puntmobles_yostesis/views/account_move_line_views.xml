<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Esto para requerir impuestos en líneas de factura-->
    <record id="view_move_form_inherit_tax_required" model="ir.ui.view">
        <field name="name">account.move.form.tax.required</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='line_ids']/tree" position="inside">
                <field name="company_invoice_line_tax_required" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='line_ids']/tree/field[@name='tax_ids']" position="attributes">
                <attribute name="attrs">
                    {
                        'required': [
                            ('company_invoice_line_tax_required', '=', True),
                            ('display_type', '=', False),
                            ('exclude_from_invoice_tab', '=', False)
                        ]
                    }
                </attribute>
            </xpath>

        </field>
    </record>
</odoo>
