<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="account_payment_order_form_custom" model="ir.ui.view">
        <field name="name">account.payment.order.form.custom</field>
        <field name="model">account.payment.order</field>
        <field name="inherit_id" ref="account_payment_order.account_payment_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_mode_id']" position="after">
                <field name="custom_confirmation_date" />
            </xpath>
        </field>
    </record>
</odoo>
