<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view_purchase_collection" model="ir.ui.view">
        <field name="name">product.template.form.purchase.collection</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <field name="categ_id" position="after">
                <field name="purchase_collection"/>
            </field>
        </field>
    </record>

    <record id="product_template_tree_view_purchase_collection" model="ir.ui.view">
        <field name="name">product.template.tree.purchase.collection</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="categ_id" position="after">
                <field name="purchase_collection" optional="hide"/>
            </field>
        </field>
    </record>

    <record id="product_template_search_view_purchase_collection" model="ir.ui.view">
        <field name="name">product.template.search.purchase.collection</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <filter name="categ_id" position="after">
                <filter string="Colección Compra" name="group_purchase_collection"
                        context="{'group_by': 'purchase_collection'}"/>
            </filter>
        </field>
    </record>

</odoo>
