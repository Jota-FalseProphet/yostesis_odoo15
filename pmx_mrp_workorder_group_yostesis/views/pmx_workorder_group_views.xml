<odoo>
  <data>

    <record id="view_pmx_workorder_group_tree" model="ir.ui.view">
      <field name="name">pmx.workorder.group.tree</field>
      <field name="model">pmx.workorder.group</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name"/>
          <field name="start_date"/>
          <field name="state"/>
          <field name="workorder_ids" widget="many2many_tags"/>
        </tree>
      </field>
    </record>

    <record id="view_pmx_workorder_group_form" model="ir.ui.view">
      <field name="name">pmx.workorder.group.form</field>
      <field name="model">pmx.workorder.group</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="start_date"/>
              <field name="state"/>
            </group>
            <notebook>
              <page string="Workorders">
                <field name="workorder_ids">
                  <tree>
                    <field name="name"/>
                    <field name="workcenter_id"/>
                    <field name="state"/>
                    <field name="pmx_group_name"/>
                    <field name="pmx_group_start_date"/>
                  </tree>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_pmx_workorder_group" model="ir.actions.act_window">
      <field name="name">Workorder Groups</field>
      <field name="res_model">pmx.workorder.group</field>
      <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_pmx_root" name="PMX" parent="mrp.menu_mrp_root" sequence="90"/>
    <menuitem id="menu_pmx_workorder_groups" name="Workorder Groups" parent="menu_pmx_root" action="action_pmx_workorder_group" sequence="10"/>

  </data>
</odoo>
