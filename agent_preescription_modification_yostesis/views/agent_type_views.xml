<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="agent_type_yostesis_view_tree" model="ir.ui.view">
        <field name="name">agent.type.yostesis.tree</field>
        <field name="model">agent.type.yostesis</field>
        <field name="arch" type="xml">
            <tree string="Tipos de Agente" editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="agent_type_yostesis_view_form" model="ir.ui.view">
        <field name="name">agent.type.yostesis.form</field>
        <field name="model">agent.type.yostesis</field>
        <field name="arch" type="xml">
            <form string="Tipo de Agente">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="agent_type_yostesis_action" model="ir.actions.act_window">
        <field name="name">Tipos de Agente</field>
        <field name="res_model">agent.type.yostesis</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
