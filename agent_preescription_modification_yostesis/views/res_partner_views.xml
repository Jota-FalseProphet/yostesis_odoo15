<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_partner_view_form_agent_type_yostesis" model="ir.ui.view">
        <field name="name">res.partner.form.agent.type.yostesis</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="groups_id" eval="[(4, ref('commission.group_commission_user'))]"/>
        <field name="priority" eval="19"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='agent_information']//field[@name='agent_type']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='agent_information']//field[@name='agent_type']" position="after">
                <field
                    name="agent_type_yostesis_id"
                    options="{'no_quick_create': True}"
                    attrs="{'required': [('agent', '=', True)], 'invisible': [('agent', '=', False)]}"
                />
            </xpath>
        </field>
    </record>

</odoo>
