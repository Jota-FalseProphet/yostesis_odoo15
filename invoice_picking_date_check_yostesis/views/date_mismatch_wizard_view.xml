<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_invoice_picking_date_mismatch_wizard_form" model="ir.ui.view">
        <field name="name">invoice.picking.date.mismatch.wizard.form</field>
        <field name="model">invoice.picking.date.mismatch.wizard</field>
        <field name="arch" type="xml">
            <form>
                <div class="alert alert-warning" role="alert">
                    <strong>Atención:</strong> Los siguientes productos tienen una fecha de recepción
                    en un mes/año diferente a la fecha contable de la factura.
                    ¿Desea confirmar la factura de todas formas?
                </div>
                <field name="line_ids" nolabel="1">
                    <tree editable="bottom" create="false" delete="false">
                        <field name="product_id"/>
                        <field name="picking_id"/>
                        <field name="date_done" widget="date"/>
                        <field name="move_date"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_confirm"
                            string="Confirmar de todas formas"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
