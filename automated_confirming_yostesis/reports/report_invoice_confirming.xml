<odoo>
  <template id="report_invoice_document_confirming_label"
            inherit_id="account.report_invoice_document">
    <xpath expr="//t[@t-foreach='payments_vals']" position="attributes">
      <attribute name="t-foreach">
        [p for p in payments_vals if not (p.get('is_confirming_risk') and any(x.get('is_confirming') for x in payments_vals))]
      </attribute>
    </xpath>
    <xpath expr="//i[contains(@class, 'oe_payment_label')]" position="replace">
      <i class="oe_form_field text-end oe_payment_label">
        <t t-if="payment_vals.get('is_confirming')">
          <t t-translation="on">Paid at Maturity on</t>
        </t>
        <t t-else="">
          <t t-translation="on">Paid on</t>
        </t>
        <t t-out="payment_vals['date']" t-options="{'widget': 'date'}"/>
      </i>
    </xpath>
  </template>
</odoo>
